      "updated": 1783207744923,
      "link": null,
      "locked": false,
      "text": "A ^ A = 0\nA ^ B = B ^ A\nA ^ (B ^ C) = (A ^ B) ^ C",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A ^ A = 0\nA ^ B = B ^ A\nA ^ (B ^ C) = (A ^ B) ^ C",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jQvrXzI_E807RUDd3Y5-T",
      "type": "text",
      "x": -368.5757137556521,
      "y": 53.70903904695933,
      "width": 352.1597595214844,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3Y",
      "roundness": null,
      "seed": 978300020,
      "version": 324,
      "versionNonce": 1356735689,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783807329494,
      "link": null,
      "locked": false,
      "text": "As per ZM's idea:\n- Store color in last two bits of\nparent (blocks are aligned to 4 byte\naddress, so last two bits can be\nignored)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "As per ZM's idea:\n- Store color in last two bits of\nparent (blocks are aligned to 4 byte\naddress, so last two bits can be\nignored)",
      "autoResize": true,
      "lineHeight": 1.25
    },
